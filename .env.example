# ========================================
# REQUIRED
# ========================================
SUPABASE_URL=https://your-project.supabase.co
SUPABASE_KEY=your-supabase-anon-key

# ========================================
# AI APIs (Required for full pipeline)
# ========================================
OPENROUTER_API_KEY=             # MiMo visual relevance filter
GEMINI_API_KEY=                 # Location resolution + dynamic query generation

# ========================================
# IMAGE SEARCH SOURCES (Optional)
# ========================================
# SERPAPI_API_KEY=              # SerpAPI Google Images (skipped if absent)
# SCRAPE_USE_BB_BROWSER=false   # Enable bb-browser daemon mode
# BB_DAEMON_URL=http://127.0.0.1:19824

# ========================================
# TUNING (Optional — sane defaults)
# ========================================
# SCRAPE_CANDIDATE_IMAGES=100
# SCRAPE_TARGET_IMAGES_MIN=12
# SCRAPE_TARGET_IMAGES_MAX=15
# SCRAPE_MIN_IMAGES=12
# SCRAPE_SKIP_DAYS=15
# SCRAPE_MIN_WIDTH=600
# SCRAPE_MIN_HEIGHT=600
# SCRAPE_AESTHETIC_MIN=6.0
# SCRAPE_CLIP_DEDUP=0.89
# SCRAPE_PHASH_DEDUP=8
# SCRAPE_DYNAMIC_QUERIES=true
# MIMO_MAX_CONCURRENT=4
